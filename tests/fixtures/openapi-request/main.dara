model OpenApiRequest {
  query?: map[string]string,
  body?: any,
  stream?: readable,
  headers?: map[string]string,
}

model Params {
  action: string,
  version: string,
}

init() {
}

// 测试函数：使用 OpenApiRequest
api testOpenApiRequest(request: OpenApiRequest): void {
  var req = new OpenApiRequest{ 
    query = request.query,
    body = request.body,
  };
  
  var params = new Params{
    action = 'TestAction',
    version = '2024-01-01',
  };
}

static function query(query: object): map[string]string;
